{
  "productName": "CeBianDesktop",
  "version": "0.1.0",
  "identifier": "com.cebian.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1742",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CeBianDesktop",
        "width": 900,
        "height": 700,
        "minWidth": 380,
        "minHeight": 500,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
